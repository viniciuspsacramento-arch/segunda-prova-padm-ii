# URL completa do banco (Railway injeta isso automaticamente como DATABASE_URL)
DATABASE_URL=mysql://root:SENHA@host:PORTA/railway

# Porta local (Railway usa a variável PORT automaticamente)
PORT=3001

# Senha do painel administrativo (/admin)
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Limite de tentativas de login no admin
ADMIN_LOGIN_MAX_TENTATIVAS=5
ADMIN_LOGIN_BLOQUEIO_MINUTOS=10
